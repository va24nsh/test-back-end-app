# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
APP_PUBLIC_URL=http://localhost:3000

# ============================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================
# Required: All database credentials must be set explicitly (no fallbacks)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mutanex_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_TEST_DB=mutanex

# ============================================
# JWT & SESSION CONFIGURATION
# ============================================
# Required: Encryption key must be 32+ characters and randomly generated
# Generate with: openssl rand -hex 32
JWT_SECRET=your_random_jwt_secret_min_32_chars_generated_with_openssl
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Required: Encryption key for OTP hashing and token encryption
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_random_encryption_key_32_chars_min_openssl_rand_hex

# ============================================
# FIREBASE CONFIGURATION
# ============================================
# Required: Firebase Admin SDK credentials
# Get these from: Firebase Console > Project Settings > Service Accounts > Node.js
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email@iam.gserviceaccount.com
# Private key should be the full PEM key (replace \n with actual newlines)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQE...\n-----END PRIVATE KEY-----"

# ============================================
# RECAPTCHA CONFIGURATION
# ============================================
# Required: reCAPTCHA v3 for protecting public APIs
# Get these from: Google Cloud Console > reCAPTCHA > Keys
RECAPTCHA_SECRET_KEY=your_recaptcha_v3_secret_key
RECAPTCHA_SCORE_THRESHOLD=0.5

# ============================================
# EMAIL PROVIDER CONFIGURATION (Brevo)
# ============================================
# Required: Brevo (formerly Sendinblue) for sending verification emails
# Get API key from: https://app-smtp.brevo.com/settings/account
BREVO_API_KEY=your_brevo_smtp_api_key
# Required: Sender email and name (used for verification email headers)
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Mutanex Patient App

# Required: Firebase email link allowlist URLs
EMAIL_LOGIN_LINK_URL=https://app.yourdomain.com/email/login
EMAIL_MAGIC_LINK_URL=https://app.yourdomain.com/email/magic-link

# ============================================
# OTP PROVIDER CONFIGURATION (MSG91 Widget)
# ============================================
# Required: OTP provider must be MSG91 Widget (NOT the standard /api/v5/otp API)
OTP_PROVIDER=msg91

# MSG91 Auth Key — from MSG91 dashboard > API Keys
MSG91_AUTH_KEY=your_msg91_auth_key

# MSG91 Widget ID — from MSG91 dashboard > OTP Widget
MSG91_WIDGET_ID=your_msg91_widget_id

# MSG91 Widget API endpoints — from MSG91 OTP Widget docs
# https://docs.msg91.com/otp-widget
MSG91_WIDGET_SEND_URL=https://control.msg91.com/api/v5/widget/sendOtp
MSG91_WIDGET_VERIFY_URL=https://control.msg91.com/api/v5/widget/verifyOtp

# Optional: retry/resend endpoint (falls back to SEND_URL if not set)
# MSG91_WIDGET_RETRY_URL=https://control.msg91.com/api/v5/widget/retryOtp

# Optional: verify access-token endpoint (only needed if using token verification step)
# MSG91_WIDGET_VERIFY_TOKEN_URL=https://control.msg91.com/api/v5/widget/verifyAccessToken

# ============================================
# CLOUD STORAGE CONFIGURATION
# ============================================
CLOUD_PROVIDER=local
STORAGE_BUCKET_NAME=mutanex-media
STORAGE_WORKSPACE_ID=default
STORAGE_SIGNING_SECRET=your_storage_signing_secret

# AWS S3 (if CLOUD_PROVIDER=aws)
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Google Cloud Storage (if CLOUD_PROVIDER=gcp)
# GCP_PROJECT_ID=your_gcp_project_id
# GCP_CLIENT_EMAIL=your_gcp_service_account_email
# GCP_PRIVATE_KEY=your_gcp_private_key

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGIN=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ============================================
# SECURITY CONFIGURATION
# ============================================
SKIP_CSRF=false
SKIP_OTP=false
