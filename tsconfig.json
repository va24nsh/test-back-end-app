{
  "compilerOptions": {
    /* === Language & Environment === */
    "target": "ES2022",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    /* === Paths & Module Resolution === */
    "paths": {
      "@config":        ["./src/config/index"],
      "@config/*":      ["./src/config/*"],
      "@controllers":   ["./src/controllers/index"],
      "@controllers/*": ["./src/controllers/*"],
      "@middlewares":   ["./src/middlewares/index"],
      "@middlewares/*": ["./src/middlewares/*"],
      "@models":        ["./src/models/index"],
      "@models/*":      ["./src/models/*"],
      "@routes":        ["./src/routes/index"],
      "@routes/*":      ["./src/routes/*"],
      "@utils":         ["./src/utils/index"],
      "@utils/*":       ["./src/utils/*"],
      "@types":         ["./src/types/index"],
      "@types/*":       ["./src/types/*"],
      "@errors":        ["./src/errors/index"],
      "@errors/*":      ["./src/errors/*"],
      "@constants":     ["./src/constants/index"],
      "@constants/*":   ["./src/constants/*"],
      "@validators":    ["./src/validators/index"],
      "@validators/*":  ["./src/validators/*"],
      "@adapters":      ["./src/adapters/index"],
      "@adapters/*":    ["./src/adapters/*"],
      "@context":       ["./src/context/index"],
      "@context/*":     ["./src/context/*"],
      "@firebase":      ["./src/firebase/index"],
      "@firebase/*":    ["./src/firebase/*"],
      "@jobs":          ["./src/jobs/index"],
      "@jobs/*":        ["./src/jobs/*"],
      "@root/*":        ["./src/*"]
    },
    /* === Type Declarations === */
    "typeRoots": ["./node_modules/@types"],
    /* === Output === */
    "rootDir": "./src",
    "outDir": "./dist",
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  /* === Files to include in compilation === */
  "include": ["src", "src/types"],
  /* === Files to exclude === */
  "exclude": ["node_modules", "dist"]
}

