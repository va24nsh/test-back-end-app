{
  "compilerOptions": {
    /* === Language & Environment === */
    "target": "ES2022",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    /* === Paths & Module Resolution === */
    "baseUrl": "./src",
    "paths": {
      "@config": ["config/index"],
      "@config/*": ["config/*"],
      "@controllers": ["controllers/index"],
      "@controllers/*": ["controllers/*"],
      "@middlewares": ["middlewares/index"],
      "@middlewares/*": ["middlewares/*"],
      "@models": ["models/index"],
      "@models/*": ["models/*"],
      "@routes": ["routes/index"],
      "@routes/*": ["routes/*"],
      "@utils": ["utils/index"],
      "@utils/*": ["utils/*"],
      "@types": ["types/index"],
      "@types/*": ["types/*"],
      "@errors": ["errors/index"],
      "@errors/*": ["errors/*"],
      "@constants": ["constants/index"],
      "@constants/*": ["constants/*"],
      "@validators": ["validators/index"],
      "@validators/*": ["validators/*"],
      "@adapters": ["adapters/index"],
      "@adapters/*": ["adapters/*"],
      "@context": ["context/index"],
      "@context/*": ["context/*"],
      "@firebase": ["firebase/index"],
      "@firebase/*": ["firebase/*"],
      "@jobs": ["jobs/index"],
      "@jobs/*": ["jobs/*"],
      "@root/*": ["*"]
    },
    /* === Type Declarations === */
    "typeRoots": ["./node_modules/@types"],
    /* === Output === */
    "rootDir": "./src",
    "outDir": "./dist",
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  /* === Files to include in compilation === */
  "include": ["src", "src/types"],
  /* === Files to exclude === */
  "exclude": ["node_modules", "dist"]
}

